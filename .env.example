# Gemini API Key (required for AI chatbot)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM provider keys are normally managed in the Admin panel
# (/adminsystem/ai → API Keys, stored in Firestore).
# The VITE_* vars below are ONLY used as a fallback when Firestore is unreachable.
# VITE_GEMINI_API_KEY=your_gemini_api_key
# VITE_DEEPSEEK_API_KEY=your_deepseek_api_key   # https://platform.deepseek.com
# VITE_MINIMAX_API_KEY=your_minimax_api_key     # https://platform.minimax.io (International)

# Firebase Configuration
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Blockchain Configuration
VITE_RPC_URL=http://localhost:8545
# For Public Testnet: VITE_RPC_URL=https://testnet.visionchain.co
