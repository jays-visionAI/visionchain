# Vision Quant Engine - Live Trading Worker
# Copy to .env and fill in values

# Firebase Service Account (JSON string - get from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Firebase Project ID (used for API key encryption)
FIREBASE_PROJECT_ID=vision-chain
